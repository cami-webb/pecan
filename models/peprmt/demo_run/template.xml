<?xml version="1.0"?>
<pecan>
 <info>
  <notes>Template for demo runs of PEPRMT using PEcAn. This file is not by itself
    a usable PEcAn settings object, will be further processed by the workflow to
    create one.</notes>
  <userid>-1</userid>
  <username></username>
 </info>
 <outdir><!-- altered at config time -->output</outdir>
 <modeloutdir><!-- altered at config time -->output/out</modeloutdir>
 <rundir><!-- altered at config time -->output/run</rundir>
 <pfts>
  <pft>
   <name>soil</name>
   <posterior.files>raw-data/pfts/soil/trait.mcmc.RData</posterior.files>
  </pft>
  <pft>
   <name>default</name>
   <posterior.files>data/pfts/default/post.distns.RData</posterior.files>
  </pft>
 </pfts>
 <ensemble>
  <size><!-- inserted at config time --></size>
  <variable>TotSoilCarb</variable>
  <samplingspace>
   <parameters>
    <method>uniform</method>
   </parameters>
   <met>
    <method>sampling</method>
   </met>
  <!-- TODO disabled for now
   <poolinitcond>
     <method>sampling</method>
   </poolinitcond> 
   <soil_physics>
    <method>sampling</method>
   </soil_physics> -->
  </samplingspace>
  <start.year><!-- inserted at config time --></start.year>
  <end.year><!-- inserted at config time --></end.year>
 </ensemble>
 <model>
  <id>peprmt_0_1_0</id>
  <type>PEPRMT</type>
  <revision>0.1.0</revision>
  <delete.raw>FALSE</delete.raw>
  <binary>/usr/local/bin/PEPRMT_v0.1.0</binary>
  <!-- TODO it seems like some settings get set here -->
 </model>
 <run>
  <site><!-- inserted at config time --></site>
  <inputs>
   <met>
    <id></id>
    <path><!-- inserted at config time --></path>
   </met>
  </inputs>
  <start.date><!-- inserted at config time --></start.date>
  <end.date><!-- inserted at config time --></end.date>
 </run>
 <host>
  <name>localhost</name>
  <outdir><!-- altered at config time -->output/out</outdir>
  <rundir><!-- altered at config time -->output/run</rundir>
 </host>
</pecan>
